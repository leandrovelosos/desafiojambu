<!DOCTYPE html>
<html>
  <head>
    <title>StarWarsExplorer</title>

    <!-- Responsividade -->
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Bootstrap CSS (via CDN) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-light">
  <!-- Fundo leve para dar contraste -->

    <!-- 🔵 NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">

        <!-- Logo / Nome -->
        <%= link_to "Star Wars Explorer", search_path, class: "navbar-brand fw-bold" %>

        <!-- Botão mobile -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>

        <!-- Conteúdo da navbar -->
        <div class="collapse navbar-collapse" id="navbarNav">

          <!-- Links à esquerda -->
          <ul class="navbar-nav me-auto">

            <li class="nav-item">
              <%= link_to "Busca", search_path, class: "nav-link" %>
            </li>

            <% if current_user %>
              <li class="nav-item">
                <%= link_to "Favoritos", favorites_path, class: "nav-link" %>
              </li>
            <% end %>

          </ul>

          <!-- Ações à direita -->
          <ul class="navbar-nav">

            <% if current_user %>
              <!-- Usuário logado -->

              <li class="nav-item">
                <span class="nav-link text-white">
                  Usuário: <%= current_user.email_address %>
                </span>
              </li>

              <li class="nav-item">
                <%= button_to "Encerrar sessão",
                  logout_path,
                  method: :delete,
                  class: "btn btn-danger btn-sm ms-2" %>
              </li>

            <% else %>
              <!-- Usuário NÃO logado -->

              <li class="nav-item">
                <%= link_to "Login", login_path, class: "btn btn-success btn-sm me-2" %>
              </li>

              <li class="nav-item">
                <%= link_to "Cadastro", signup_path, class: "btn btn-primary btn-sm" %>
              </li>

            <% end %>

          </ul>

        </div>
      </div>
    </nav>

    <!-- 🔔 Flash messages -->
    <div class="container mt-3">
      <% if notice %>
        <div class="alert alert-success"><%= notice %></div>
      <% end %>

      <% if alert %>
        <div class="alert alert-danger"><%= alert %></div>
      <% end %>
    </div>

    <!-- 📦 Conteúdo principal -->
    <div class="container mt-4">
      <%= yield %>
    </div>

    <!-- Bootstrap JS (necessário para navbar funcionar no mobile) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>