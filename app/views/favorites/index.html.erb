<h1 class="mb-4"><%= t("favorites.title") %></h1>

<% if @grouped_favorites.present? %>

  <% @grouped_favorites.each do |category, favorites| %>

    <div class="card mb-4 shadow-sm">

      <!-- Cabeçalho -->
      <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">

        <span>
          <%= t("favorites.categories.#{category}", default: category.humanize) %>
        </span>

        <span class="badge bg-light text-dark">
          <%= favorites.count %>
        </span>

      </div>

      <ul class="list-group list-group-flush">

        <% favorites.each do |fav| %>

          <li class="list-group-item d-flex justify-content-between align-items-center">

            <%= link_to fav.name,
                details_path(url: fav.url),
                class: "text-decoration-none fw-bold" %>

            <%= button_to t("favorites.remove"),
              favorite_path(fav),
              method: :delete,
              data: { confirm: t("favorites.confirm") },
              class: "btn btn-sm btn-outline-danger" %>

          </li>

        <% end %>

      </ul>

    </div>

  <% end %>

<% else %>

  <div class="alert alert-info text-center">
    <%= t("favorites.empty") %>
  </div>

<% end %>