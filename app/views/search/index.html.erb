<!-- app/views/search/index.html.erb -->

<h1>Busca Star Wars</h1>
<!-- Título principal da página -->

<!-- 🔎 FORMULÁRIO DE BUSCA dentro de um card (melhor organização visual) -->
<div class="card mb-4">
  <div class="card-body">

    <h5 class="card-title">Buscar na API</h5>
    <!-- Título interno do card -->

    <%= form_with url: search_path, method: :get, local: true do |f| %>
    <!-- Formulário GET para /search -->

      <!-- 🔹 Campo de categoria -->
      <div class="mb-3">
        <%= f.label :category, "Categoria" %>
        <!-- Label do select -->

        <%= f.select :category,
          options_for_select([
            ["Personagens", "people"],   # endpoint /people
            ["Planetas", "planets"],     # endpoint /planets
            ["Naves", "starships"]       # endpoint /starships
          ], @category),
          {},
          class: "form-select"
        %>
        <!-- Select define qual endpoint da SWAPI será usado -->
      </div>

      <!-- 🔹 Campo de busca COM autocomplete -->
      <div class="mb-3 position-relative">
        <!-- position-relative permite posicionar sugestões "por cima" -->

        <%= f.label :query, "Buscar por nome" %>

        <%= f.text_field :query,
          value: @query,
          class: "form-control",
          id: "search-input",     # usado no JS
          autocomplete: "off"     # desativa autocomplete do browser
        %>
        <!-- Campo onde o usuário digita -->

        <!-- 🔽 Dropdown de sugestões -->
        <div id="suggestions"
             class="list-group position-absolute w-100"
             style="z-index: 1000;">
        </div>
        <!-- Aparece dinamicamente via JavaScript -->
      </div>

      <!-- 🔹 Botão de submit -->
      <%= f.submit "Buscar", class: "btn btn-primary" %>

    <% end %>

  </div>
</div>

<hr>
<!-- Separador visual -->

<h2>Resultados</h2>

<% if @results.present? %>
<!-- Se houver resultados da API -->

  <ul class="list-group">

    <% @results.each do |item| %>
    <!-- Loop pelos resultados -->

      <li class="list-group-item d-flex justify-content-between align-items-center">
      <!-- Layout horizontal com Bootstrap -->

        <!-- 🔹 Nome clicável -->
        <div>
          <%= link_to item["name"],
              details_path(url: item["url"]),
              class: "text-decoration-none fw-bold" %>
          <!-- Leva para tela de detalhes -->
        </div>

        <!-- 🔹 Botão de favoritar (somente logado) -->
        <% if current_user %>

          <%= form_with url: favorites_path, method: :post, local: true, class: "mb-0" do %>

            <%= hidden_field_tag :name, item["name"] %>
            <!-- Nome do item -->

            <%= hidden_field_tag :category, @category %>
            <!-- Categoria atual -->

            <%= hidden_field_tag :query, @query %>
            <!-- Mantém contexto da busca -->

            <%= hidden_field_tag :url, item["url"] %>
            <!-- URL do recurso na API -->

            <%= submit_tag "Favoritar", class: "btn btn-sm btn-success" %>

          <% end %>

        <% end %>

      </li>

    <% end %>

  </ul>

<% elsif @category.present? %>
<!-- Caso buscou mas não encontrou nada -->

  <p class="text-muted">Nenhum resultado encontrado.</p>

<% end %>

<!-- 🔄 Paginação -->
<% if @results.present? %>

  <div class="mt-3 d-flex justify-content-between">

    <!-- 🔹 Página anterior -->
    <% if @prev_page %>
      <%= link_to "⬅ Anterior",
        search_path(category: @category, query: @query, page_url: @prev_page),
        class: "btn btn-outline-secondary" %>
    <% end %>

    <!-- 🔹 Próxima página -->
    <% if @next_page %>
      <%= link_to "Próxima ➡",
        search_path(category: @category, query: @query, page_url: @next_page),
        class: "btn btn-outline-primary ms-auto" %>
    <% end %>

  </div>

<% end %>