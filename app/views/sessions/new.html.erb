<!-- Container centralizado -->
<div class="row justify-content-center">
  <div class="col-md-6">

    <!-- Card principal -->
    <div class="card shadow-sm">
      <div class="card-body">

        <h3 class="card-title mb-4 text-center">Login</h3>
        <!-- Título centralizado -->

        <%= form_with url: login_path, method: :post, local: true do |f| %>
        <!-- Formulário de login -->

          <div class="mb-3">
            <%= f.label :email_address, "Email" %>
            <!-- Label -->

            <%= f.email_field :email_address, class: "form-control" %>
            <!-- Campo de email -->
          </div>

          <div class="mb-3">
            <%= f.label :password, "Senha" %>

            <%= f.password_field :password, class: "form-control" %>
            <!-- Campo de senha -->
          </div>

          <div class="d-grid">
            <%= f.submit "Entrar", class: "btn btn-primary" %>
            <!-- Botão ocupa largura total -->
          </div>

        <% end %>

      </div>
    </div>

  </div>
</div>